decimal_num = int(input("Enter a decimal number:"))
if decimal_num == 0:
    binary_str = "0"
else:
    binary_str = ""

while decimal_num > 0:
    remainder = decimal_num % 2
    binary_str = str(remainder) + binary_str
    decimal_num = decimal_num // 2
    print("Binary conversion:", binary_str)


